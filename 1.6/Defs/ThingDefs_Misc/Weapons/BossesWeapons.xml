<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!-- ==================== DOMINUS MECHLANCE ==================== -->
	<ThingDef ParentName="BaseGun" Name="APM_Weapon_DominusMechlance_Base" Abstract="True">
		<techLevel>Spacer</techLevel>
		<uiIconScale>0.5</uiIconScale>
		<destroyOnDrop>true</destroyOnDrop>
		<tradeability>None</tradeability>
		<statBases>
			<Mass>2.0</Mass>
			<WorkToMake>30000</WorkToMake>
		</statBases>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>1.5</drawSize>
		</graphicData>
		<tools>
			<li>
				<label>handle</label>
				<capacities><li>Blunt</li></capacities>
				<power>10</power>
				<cooldownTime>1.8</cooldownTime>
			</li>
			<li>
				<label>point</label>
				<capacities><li>Stab</li></capacities>
				<power>27</power>
				<cooldownTime>2.0</cooldownTime>
			</li>
			<li>
				<label>edge</label>
				<capacities><li>Cut</li></capacities>
				<power>34</power>
				<cooldownTime>2.0</cooldownTime>
			</li>
		</tools>
		<modExtensions>
			<li Class="VEF.Things.ThingDefExtension" MayRequire="OskarPotocki.VanillaFactionsExpanded.Core">
				<usableWithShields>true</usableWithShields>
				<weaponDraftedDrawOffsets>
					<north><drawOffset>(-0.30, 0.00, 0.15)</drawOffset><angleOffset>-120</angleOffset></north>
					<east><drawOffset>(0.50, 0.00, 0.15)</drawOffset><angleOffset>-60</angleOffset></east>
					<south><drawOffset>(0.30, 0.00, 0.15)</drawOffset><angleOffset>-60</angleOffset></south>
					<west><drawOffset>(-0.50, 0.00, 0.15)</drawOffset><angleOffset>60</angleOffset></west>
				</weaponDraftedDrawOffsets>
			</li>
		</modExtensions>
	</ThingDef>

	<ThingDef ParentName="APM_Weapon_DominusMechlance_Base">
		<defName>APM_Weapon_DominusMechlance</defName>
		<label>Dominus mechlance</label>
		<description>This weapon is imbued with sharpness maintaining mechanites similar to those seen in imperial monotech. Such a technology being utilized by the mechhive allows the hive to apply it on larger and more complex applications, such as this deadly weapon.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponMelee/Boss/Mechlance</texPath>
		</graphicData>
		<weaponTags>
			<li>APM_WeaponDominusMechlance</li>
		</weaponTags>
	</ThingDef>
	
	<ThingDef ParentName="APM_Weapon_DominusMechlance_Base">
		<defName>APM_Weapon_DominusApexMechlance</defName>
		<label>Dominus apex mechlance</label>
		<description>This weapon is imbued with sharpness maintaining mechanites similar to those seen in imperial monotech. Such a technology being utilized by the mechhive allows the hive to apply it on larger and more complex applications, such as this deadly weapon. In such close proximity to the Dominus, the mechanites in this mechlance have been influenced by its psychic presence, so much so that it bleeds out in a reddish hue.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponMelee/Boss/ApexMechlance</texPath>
		</graphicData>
		<weaponTags>
			<li>APM_WeaponDominusApexMechlance</li>
		</weaponTags>
	</ThingDef>


